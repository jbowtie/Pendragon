<section class="enc-notes-section {{#unless displayNotes }}hide-enc-notes{{/unless}}">
  {{!Notes Section}}
  <div class="bold" style="margin: 10px 0px 0px 10px;">{{localize 'PEN.notes'}}</div>
  <div class="enc-notes" style="margin: 10px 0px 0px 10px;">
    {{#if editable}}
      <prose-mirror name="system.notes" value="{{system.notes}}" editable="{{editable}}" toggled="false">
        {{{enrichedNotes}}}
      </prose-mirror>
    {{else}}
      {{{enrichedNotes}}}
    {{/if}}
  </div>
</section>