<section class="npc-notes-section {{#unless displayNotes }}hide-enc-notes{{/unless}}">
  {{!--Notes Block --}}
    <div class="npc-name bold grey" style="padding-left:10px;">{{ localize "PEN.notes" }}</div>  
    <div class="npcv2-notes-doc">
      {{#if editable}}
        <prose-mirror name="system.description" value="{{system.description}}" editable="{{editable}}" toggled="false">
          {{{enrichedDescription}}}
        </prose-mirror>
      {{else}}
        {{{enrichedDescription}}}
      {{/if}}
    </div>



</section>