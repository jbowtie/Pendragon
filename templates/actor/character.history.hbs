<section class='character tab history {{tab.cssClass}}' data-group='primary' data-tab='history'>
  <div class="history-grid">  
    <div class="stat-name bold grid-item-bottom centre">{{ localize "PEN.year" }}</div>
    <div class="stat-name bold grid-item-bottom">{{ localize "PEN.event" }}</div>
    <div class="stat-name bold grid-item-bottom centre">{{ localize "PEN.glory" }}</div>
    <div class="stat-name bold grid-item-bottom centre" data-action="createDoc" data-document-class='Item' data-type="history">  
      <a class="large-icon" data-tooltip="{{localize 'PEN.addHistory'}}"><i class="item-control fas fa-plus"></i></a>
    </div> 

    {{#each history as |historical key|}}
      <div class="grid-item-bottom stat-name centre">{{historical.system.year}}</div>
      <div class="grid-item-bottom stat-name">{{historical.name}}</div>
      <div class="grid-item-bottom stat-name centre">{{historical.system.glory}}</div>
      <div class="item grid-item-bottom centre" data-itemid ="{{historical._id}}">
        <a class="item-control large-icon fade" data-action="viewDoc"><i data-tooltip="{{localize 'PEN.view'}}" class="fa-solid fa-eye"></i></a>
        {{#unless ../system.lock}}
          <a class="item-control fade large-icon" data-action="deleteDoc"><i data-tooltip="{{localize 'PEN.delete'}}" class="fas fa-broom-wide"></i></a>
        {{/unless}}
      </div>  
    {{/each}}
  </div>
  <br>
  <div class="ideal-grid">  
    <div class="stat-name bold grid-item-bottom">{{ localize "PEN.ideals" }}</div>
    <div class="stat-name bold grid-item-bottom centre">{{ localize "PEN.active" }}</div>
    <div class="grid-item-bottom"></div> 

    {{#each ideals as |ideal key|}}
      <div class="grid-item-bottom stat-name">{{ideal.name}}</div>
      <div class="grid-item-bottom stat-name centre"><a class="{{#if ideal.system.active}}darkred{{else}}fade{{/if}}"><i class="fa-solid fa-heart"></i></a></div>
      <div class="item grid-item-bottom centre" data-itemid ="{{ideal._id}}">
        <a class="item-control large-icon fade" data-action="viewDoc"><i data-tooltip="{{localize 'PEN.view'}}" class="fa-solid fa-eye"></i></a>
        {{#unless ../system.lock}}
          <a class="fade large-icon" data-action="deleteDoc" data-tooltip="{{localize 'PEN.delete'}}"><i class="item-control fas fa-broom-wide"></i></a>
        {{/unless}}
      </div>
    {{/each}}
  </div>
  <br>

  <div class="passive-grid">
    <div class="stat-name bold grid-item ">{{ localize "PEN.passive" }}</div>
    <div class="grid-item"></div>
    <div class="stat-name grid-item-bottom bold">{{localize 'PEN.ideals'}}</div>
    <div class="stat-name grid-item-bottom centre">{{system.passglory.ideals}}</div>   
    <div class="stat-name grid-item-bottom bold">{{localize 'PEN.appeal'}}</div>
    <div class="stat-name grid-item-bottom centre">{{system.appeal}}</div>   
    <div class="stat-name grid-item-bottom bold">{{localize 'PEN.sol'}}</div>
    <div class="stat-name grid-item-bottom centre">{{system.solVal}}</div>  
    <div class="stat-name grid-item-bottom bold">{{localize 'PEN.sizInc.3'}}</div>
    <div class="stat-name grid-item-bottom centre">{{system.obese}}</div>   
    <div class="stat-name grid-item-bottom bold">{{localize 'PEN.tap'}}</div>
    <div class="stat-name grid-item-bottom centre">{{system.tap}}</div>   
    <div class="stat-name grid-item-bottom bold">{{localize 'PEN.estate'}}</div>
    <div class="stat-name-input event-input grid-item-bottom centre"><input name="system.passglory.estate" type="text" value="{{system.passglory.estate}}" data-dtype="Number"/></div>
    <div class="stat-name grid-item-bottom bold">{{localize 'PEN.inyear'}}</div>
    <div class="stat-name-input event-input grid-item-bottom centre"><input name="system.passglory.inyear" type="text" value="{{system.passglory.inyear}}" data-dtype="Number"/></div>      
    <div class="stat-name grid-item-bottom bold">{{localize 'PEN.other'}}</div>
    <div class="stat-name-input event-input grid-item-bottom centre"><input name="system.passglory.other" type="text" value="{{system.passglory.other}}" data-dtype="Number"/></div>  
    <div class="stat-name grid-item-bottom bold">{{localize 'PEN.totalG'}}</div>
    <div class="stat-name grid-item-bottom bold centre">{{system.passive}}</div>   
  </div>
  <br>
</section>  