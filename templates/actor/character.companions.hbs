<section class='character tab companions {{tab.cssClass}}' data-group='primary' data-tab='companions'>
  <div class="stat-name bold">{{localize 'PEN.squires'}}</div>
  <div class="squire-grid">
    <div class="stat-name grid-item bold ">{{localize 'PEN.name'}}</div>
    <div class="stat-name grid-item bold centre">{{localize 'PEN.type'}}</div>
    <div class="stat-name grid-item bold centre">{{localize 'PEN.age'}}</div>
    <div class="stat-name grid-item bold centre">{{localize 'PEN.skill'}}</div>
    <div class="stat-name grid-item bold centre" data-tooltip="{{localize 'PEN.knightlyMod'}}">{{localize 'PEN.mod'}}</div>
    <div class="stat-name grid-item bold centre">{{localize 'PEN.glory'}}</div>
    <div class="stat-name bold grid-item centre" data-action="createDoc" data-document-class='Item' data-type="squire">  
      <a class="large-icon" data-tooltip="{{localize 'PEN.addSquire'}}"><i class="item-control fas fa-plus"></i></a>
    </div> 
  </div>  

  {{#each squires as |squire key|}}
    <li class="item squire-grid" data-drag='true' data-document-class='Item' data-item-id="{{squire._id}}">
      <div class="stat-name grid-item rollable squire" data-tooltip="{{localize 'PEN.rollHint'}}" data-type ="squire" data-itemid="{{squire._id}}">{{squire.name}}</div>
      <div class="stat-name grid-item centre">{{squire.system.squireType}}</div>
      <div class="stat-name grid-item centre rollable squire" data-tooltip="{{localize 'PEN.rollHint'}}" data-type ="squireAge" data-itemid="{{squire._id}}">{{squire.system.age}}</div>
      <div class="stat-name grid-item centre">{{squire.system.skill}}</div>
      <div class="stat-name grid-item centre">{{squire.system.knightMod}}</div>
      <div class="stat-name grid-item centre">{{squire.system.glory}}</div>
      <div class="centre grid-item item" data-itemid ="{{squire._id}}">
        <a class="item-control large-icon fade" data-action="viewDoc"><i data-tooltip="{{localize 'PEN.view'}}" class="fa-solid fa-eye"></i></a>
        {{#unless ../system.lock}}
          <a class="item-control large-icon fade" data-action="deleteDoc"><i data-tooltip="{{localize 'PEN.delete'}}" class="fa-solid fa-broom-wide"></i></a>
        {{/unless}}
      </div>  
    </li>
  {{/each}}
  <div class="squire-grid"></div>


  <br>
  <div class="stat-name bold">{{localize 'PEN.horses'}}</div>
  <div class="companion-grid">
    <div class="stat-name grid-item bold" data-tooltip="{{localize 'PEN.rideHint'}}">{{localize 'PEN.ride'}}</div>
    <div class="stat-name grid-item bold">{{localize 'PEN.type'}}</div>
    <div class="stat-name grid-item centre bold">{{localize 'PEN.ap'}}</div>
    <div class="stat-name grid-item centre bold">{{localize 'PEN.mov'}}</div>
    <div class="stat-name grid-item centre bold">{{localize 'PEN.damage'}}</div>
    <div class="stat-name grid-item centre bold">{{localize 'PEN.hpShort'}}</div>
    <div class="stat-name grid-item centre bold">{{localize 'PEN.maxHP'}}</div>
    <div class="stat-name grid-item centre bold">{{localize 'PEN.health'}}</div>
    <div class="stat-name grid-item centre bold">{{localize 'PEN.care'}}</div>
    <div class="stat-name bold grid-item centre" data-action="createDoc" data-document-class='Item' data-type="horse">  
      <a class="large-icon" data-tooltip="{{localize 'PEN.addHorse'}}"><i class="item-control fas fa-plus"></i></a>
    </div> 
  </div>  

  {{#each horses as |horse key|}}
    <li class="item companion-grid" data-drag='true' data-document-class='Item' data-item-id="{{horse._id}}">
      <div class="grid-item middle centre">
        <a class="item-control item-toggle large-icon" data-itemid ="{{horse._id}}" data-property="equipped" data-tooltip="{{localize 'PEN.dblClickToggle'}}"><i class="{{#if horse.system.equipped}}fa-regular fa-square-check{{else}}fa-regular fa-square{{/if}}"></i></a>
      </div>
      <div class="stat-name grid-item" data-tooltip="{{horse.name}}">{{horse.system.label}}</div>
      <div class="stat-name grid-item centre">{{horse.system.totalAR}}</div>
      <div class="stat-name grid-item centre">{{horse.system.move}}</div>
      <div class="stat-name grid-item centre rollable damage" data-tooltip="{{localize 'PEN.chargeDmgHint'}}: {{horse.system.chargeDmg}}" data-itemid="{{horse._id}}">{{horse.system.damage}}</div>
      <div class="dam-name-input item grid-item centre dam-value" data-field="horse" data-itemid ="{{horse._id}}"><input class="inline-edit" name="item.system.horse.{{key}}.hp" type="text" value="{{horse.system.hp}}" data-dtype="Number"/></div>
      <div class="stat-name grid-item centre">{{horse.system.maxHP}}</div>
      <div class="stat-name grid-item centre">{{horse.system.healthName}}</div>
      <div class="stat-name grid-item centre">{{horse.system.careName}}</div>
      <div class="centre grid-item item" data-itemid ="{{horse._id}}">
        <a class="item-control large-icon fade" data-action="viewDoc"><i data-tooltip="{{localize 'PEN.view'}}" class="fa-solid fa-eye"></i></a>
      {{#unless ../system.lock}}
        <a class="item-control large-icon fade" data-action="deleteDoc"><i data-tooltip="{{localize 'PEN.delete'}}" class="fa-solid fa-broom-wide"></i></a>
      {{/unless}}
      </div>  
    </li>
  {{/each}}
  <div class="companion-grid"></div>

  <br>
  <div class="stat-name bold">{{localize 'PEN.equestrian'}}</div>
  <div class="equestrian-input"><input name="system.equestrian" type="text" value="{{actor.system.equestrian}}"/></div>

  <br>
  <div class="stat-name bold">{{localize 'PEN.joust'}}</div>
  <div class="joust-grid">
  <div class="stat-name">{{localize 'PEN.wins'}}</div>  
  <div class="dam-name-input"><input name="system.joust.wins" type="text" value="{{actor.system.joust.wins}}" data-dtype="Number"/></div>
  <div class="stat-name">{{localize 'PEN.losses'}}</div>  
  <div class="dam-name-input"><input name="system.joust.losses" type="text" value="{{actor.system.joust.losses}}" data-dtype="Number"/></div>
  </div>
  <br>
</section>  